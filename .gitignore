#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
pubspec.lock

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
# Flavor-specific build artifacts (AABs / APKs). Pattern matches
# android/app/<flavor>/release/, e.g. android/app/prod/release/.
/android/app/*/release/
/android/app/*/debug/
/android/app/*/profile/

# FVM Version Cache
.fvm/
.fvmrc

