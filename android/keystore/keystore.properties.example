# Copy this file to keystore.properties (same directory) and fill in real
# values. The real keystore.properties is gitignored — never commit it.
#
# storeFile is resolved relative to android/app/build.gradle.kts, so the
# .jks file living next to this properties file is referenced as
# `../keystore/<filename>.jks`.
storePassword=YOUR_STORE_PASSWORD_HERE
keyPassword=YOUR_KEY_PASSWORD_HERE
keyAlias=YOUR_KEY_ALIAS_HERE
storeFile=../keystore/your_keystore_filename.jks
