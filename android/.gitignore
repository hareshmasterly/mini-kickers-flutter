# Remember to never publicly share your keystore.
# See https://flutter.dev/to/reference-keystore
key.properties
keystore.properties
**/*.keystore
**/*.jks
# Belt-and-braces: ignore everything inside android/keystore/ except the
# *.example placeholders, which are safe to commit. Note: we use
# `keystore/*` (not `keystore/`) — git can't re-include files under an
# excluded *directory*, only under excluded *contents*.
keystore/*
!keystore/*.example
